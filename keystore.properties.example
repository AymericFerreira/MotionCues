# Copy this file to "keystore.properties" (which is gitignored) and fill in your values.
# With it present, `./gradlew bundleRelease` produces a SIGNED .aab ready to upload to Play.
#
# 1. Generate an upload keystore (keep this .jks safe and OUT of git — it is gitignored):
#
#      keytool -genkey -v -keystore upload.jks -keyalg RSA -keysize 2048 \
#              -validity 10000 -alias upload
#
# 2. Put upload.jks at the repo root (or set storeFile to a path relative to the repo root).
# 3. Fill in the passwords/alias below.
#
# Losing this keystore (or its passwords) means you can never update the app again under the
# same upload identity — back it up somewhere safe. (Play App Signing mitigates this; enroll
# when you create the app.)

storeFile=upload.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
