    <!-- Onboarding -->
    <string name="onboard_title">Motion Cues</string>
    <string name="onboard_intro">Reduce car-sickness with a field of dots that drift opposite to your vehicle\'s motion, giving your eyes a cue that matches what your inner ear feels.</string>
    <string name="onboard_limitation_title">Works over your apps</string>
    <string name="onboard_limitation_body">The dots appear over normal apps like readers and browsers. They cannot be drawn over the status bar, notification shade, Quick Settings, or lock screen — that needs a system feature Android hasn\'t released yet. Every third-party app has this limit.</string>
    <string name="onboard_perm_overlay_title">Allow drawing over other apps</string>
    <string name="onboard_perm_overlay_body">Required to show the dots on top of the app you\'re reading.</string>
    <string name="onboard_perm_overlay_button">Grant overlay permission</string>
    <string name="onboard_perm_overlay_granted">Overlay permission granted</string>
    <string name="onboard_perm_notif_title">Allow notifications</string>
    <string name="onboard_perm_notif_body">A small ongoing notification keeps the overlay running while you travel.</string>
    <string name="onboard_perm_notif_button">Allow notifications</string>
